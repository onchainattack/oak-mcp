{
  "name": "@onchainattack/oak-mcp",
  "version": "0.1.0",
  "description": "MCP server exposing the OAK (OnChain Attack Knowledge) framework as queryable tools for AI coding agents.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "oak-mcp": "./dist/server.js"
  },
  "main": "./dist/server.js",
  "files": [
    "dist/",
    "data/embedded.json",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "fetch-data": "node scripts/fetch-data.mjs",
    "build": "npm run fetch-data && tsc",
    "prepare": "npm run build",
    "start": "node dist/server.js",
    "dev": "tsx src/server.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "ai",
    "claude",
    "cursor",
    "crypto-security",
    "onchain",
    "blockchain-security",
    "threat-intelligence",
    "oak"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/onchainattack/oak-mcp.git"
  },
  "homepage": "https://onchainattack.org",
  "bugs": "https://github.com/onchainattack/oak-mcp/issues"
}
