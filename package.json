{
  "name": "@onchainattack/oak-mcp",
  "version": "0.2.0",
  "description": "MCP server exposing the OAK (OnChain Attack Knowledge) framework as queryable tools for AI coding agents.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "oak-mcp": "dist/server.js"
  },
  "main": "./dist/server.js",
  "files": [
    "dist/",
    "README.md",
    "LICENSE",
    "NOTICE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc",
    "build:offline": "tsc",
    "prepare": "tsc",
    "start": "node dist/server.js",
    "dev": "tsx src/server.ts",
    "typecheck": "tsc --noEmit",
    "pretest": "tsc",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "ai",
    "claude",
    "cursor",
    "crypto-security",
    "onchain",
    "blockchain-security",
    "threat-intelligence",
    "oak"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/onchainattack/oak-mcp.git"
  },
  "homepage": "https://onchainattack.org",
  "bugs": "https://github.com/onchainattack/oak-mcp/issues"
}
